<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if title %}{{ title }} | {% endif %}TGV Max Explorer</title>
    <meta name="description" content="{% if description %}{{ description }}{% else %}Explore todos os destinos disponíveis com o TGV Max{% endif %}">
    <link rel="stylesheet" href="/css/style.css">
    
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>

</head>
<body>
    <header>
        <div class="container">
            <h1>TGV Max Explorer</h1>
            <nav>
                <a href="/">Início</a>
                <a href="/destinations/">Destinos</a>
                <a href="/map/">Mapa</a>
                <a href="/about/">Sobre</a>
            </nav>
        </div>
    </header>
    
    <main class="container">
        {{ content | safe }}
    </main>
    
    <footer>
        <div class="container">
            <p>&copy; 2025 TGV Max Explorer | Desenvolvido por Felipe Bado dos Reis</p>
        </div>
    </footer>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="/js/main.js"></script> 
</body>
</html>
